DATA_DIR=./data           # path for SQLite DB and attachments
PORT=9000
HOST=0.0.0.0
ADMIN_PASSWORD=           # initial admin password (only used on first run)
APP_VERSION=              # shown in footer (e.g. v1.0.0)
TRUST_PROXY=0             # set to 1 if behind a reverse proxy
SESSION_DAYS=7            # session lifetime in days, clamped to 1-90
NOTIFY_CHECK_HOURS=24     # how often to run notification checks (1-168 hrs)
